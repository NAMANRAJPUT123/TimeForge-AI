# ==============================================================================
# Environment Variables Blueprint (.env.example)
# ==============================================================================
# Copy this file to a new file named '.env' in the same directory and replace
# the placeholders with your actual keys and configuration details.
#
# DO NOT commit your actual '.env' file containing real secrets to GitHub!
# ==============================================================================

# ------------------------------------------------------------------------------
# 🛡️ Google Gemini AI API Configuration (Server-Side Only)
# ------------------------------------------------------------------------------
# Required for server-side smart analysis, AI task scheduling, and assistant chat.
# Obtain a key in Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY="your_gemini_api_key_here"

# ------------------------------------------------------------------------------
# 🌐 Application Environment Configuration (Server-Side Only)
# ------------------------------------------------------------------------------
NODE_ENV="development"

# ------------------------------------------------------------------------------
# 🗄️ Database Connection (Drizzle ORM / PostgreSQL - Server-Side Only)
# ------------------------------------------------------------------------------
# Details for connecting to the PostgreSQL relational database.
SQL_HOST="localhost"
SQL_USER="postgres"
SQL_PASSWORD="your_database_password_here"
SQL_DB_NAME="deadline_guardian"

# ------------------------------------------------------------------------------
# 🔥 Firebase client-side Web SDK Configuration (Vite prefixed - Frontend Only)
# ------------------------------------------------------------------------------
# Frontend keys used to initialize Google Sign-In and Cloud Firestore connections.
VITE_FIREBASE_API_KEY="your_firebase_api_key_here"
VITE_FIREBASE_AUTH_DOMAIN="your-app-id.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-app-id"
VITE_FIREBASE_APP_ID="1:1234567890:web:1234567890abcdef"
VITE_FIREBASE_DATABASE_ID="(default)"
VITE_FIREBASE_STORAGE_BUCKET="your-app-id.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="1234567890"

# ------------------------------------------------------------------------------
# 🔥 Firebase Admin SDK Configuration (Server-side Only)
# ------------------------------------------------------------------------------
# Server variables for identity token verification and direct admin Firestore operations.
FIREBASE_PROJECT_ID="your-app-id"
FIREBASE_DATABASE_ID="(default)"
